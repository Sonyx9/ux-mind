---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="O nás"
  description="Tým UX specialistů zaměřených na výzkum uživatelů, eye tracking a UX audit. Pomáháme firmám vytvářet lepší produkty."
>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-16">
        <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ O NÁS ]</p>
        <h1 class="font-display font-bold leading-none tracking-tighter mb-8" style="font-size: clamp(3rem, 9vw, 8rem);">
          TÝM<br/>ODBORNÍKŮ.
        </h1>
      </div>

      <!-- About text -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-24">
        <div>
          <p class="text-xl text-brand-black/60 leading-relaxed mb-6">
            UX Mind je tým specialistů na výzkum uživatelů, kteří věří, že nejlepší produkty vznikají z hlubokého porozumění lidem.
          </p>
          <p class="text-brand-black/60 leading-relaxed">
            Kombinujeme pokročilé technologie eye trackingu s osvědčenými metodami UX výzkumu. Naši klienti jsou startupy i korporace, které chtějí dělat rozhodnutí na základě dat, ne domněnek.
          </p>
        </div>
        <div>
          <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ NAŠE HODNOTY ]</p>
          <ul class="space-y-4">
            {[
              { title: 'Data nad dojmy', desc: 'Každé doporučení podložené výzkumem.' },
              { title: 'Empatie k uživatelům', desc: 'Rozumíme lidem, ne jen metrikám.' },
              { title: 'Praktická doporučení', desc: 'Výstupy, které se dají skutečně implementovat.' },
              { title: 'Transparentnost', desc: 'Jasná komunikace procesu i výsledků.' },
            ].map(value => (
              <li class="border-b border-brand-black/10 pb-4">
                <p class="font-semibold mb-1">{value.title}</p>
                <p class="text-sm text-brand-black/60">{value.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center py-16 border-t border-brand-black/10">
        <h2 class="font-display text-4xl font-bold mb-6">Pojďme spolupracovat</h2>
        <a href="/kontakt" class="inline-block border border-brand-black px-8 py-4 font-mono text-xs tracking-widest uppercase hover:bg-brand-black hover:text-brand-white transition-colors">
          NAPSAT NÁM →
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
