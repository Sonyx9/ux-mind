---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Kontakt"
  description="Kontaktujte UX Mind. Domluvte si nezávaznou konzultaci UX auditu, eye trackingu nebo UX výzkumu."
>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-16">
        <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ KONTAKT ]</p>
        <h1 class="font-display font-bold leading-none tracking-tighter mb-8" style="font-size: clamp(3rem, 9vw, 8rem);">
          POJĎME<br/>MLUVIT.
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

        <!-- Contact info -->
        <div>
          <p class="text-xl text-brand-black/60 leading-relaxed mb-12">
            Rádi si vyslechneme váš projekt. Napište nám nebo rovnou vyplňte formulář a ozveme se do 24 hodin.
          </p>

          <div class="space-y-6">
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">EMAIL</p>
              <a href="mailto:info@uxmind.cz" class="font-display text-2xl font-bold hover:opacity-50 transition-opacity">
                info@uxmind.cz
              </a>
            </div>
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">TELEFON</p>
              <a href="tel:+420000000000" class="font-display text-2xl font-bold hover:opacity-50 transition-opacity">
                +420 000 000 000
              </a>
            </div>
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">SÍDLO</p>
              <p class="font-display text-xl font-bold">Praha, Česká republika</p>
            </div>
          </div>

          <div class="mt-12 p-6 border border-brand-black/10">
            <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-3">[ ODPOVÍDÁME DO ]</p>
            <p class="font-display text-3xl font-bold">24 hodin</p>
            <p class="text-sm text-brand-black/50 mt-1">v pracovní dny</p>
          </div>
        </div>

        <!-- Contact form -->
        <div>
          <form class="space-y-6" name="kontakt" method="POST" data-netlify="true">
            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">JMÉNO *</label>
              <input
                type="text"
                name="name"
                required
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="Vaše jméno"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">EMAIL *</label>
              <input
                type="email"
                name="email"
                required
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="vas@email.cz"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">FIRMA</label>
              <input
                type="text"
                name="company"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="Název firmy"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">ZÁJEM O SLUŽBU</label>
              <select
                name="service"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent appearance-none"
              >
                <option value="">Vyberte službu...</option>
                <option value="ux-audit">UX Audit</option>
                <option value="eye-tracking">Eye Tracking</option>
                <option value="ux-vyzkum">UX Výzkum</option>
                <option value="testovani">Testování uživatelů</option>
                <option value="konzultace">Konzultace</option>
                <option value="jine">Jiné</option>
              </select>
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">ZPRÁVA *</label>
              <textarea
                name="message"
                required
                rows="5"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent resize-none"
                placeholder="Popište váš projekt nebo dotaz..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full border border-brand-black px-8 py-4 font-mono text-xs tracking-widest uppercase hover:bg-brand-black hover:text-brand-white transition-colors"
            >
              ODESLAT ZPRÁVU →
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
