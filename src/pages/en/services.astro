---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  lang="en"
  title="Services"
  description="UX audit, eye tracking, UX research and user testing. A comprehensive portfolio of UX services for digital products."
>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-24">
        <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ OUR SERVICES ]</p>
        <h1 class="font-display font-bold leading-none tracking-tighter" style="font-size: clamp(3.5rem, 10vw, 9rem);">
          WHAT WE<br/>DO.
        </h1>
      </div>

      <div class="space-y-px border border-brand-black/10">
        {[
          {
            num: '01',
            title: 'UX Audit',
            desc: 'A systematic analysis of your digital product. We walk through the interface from the user\'s perspective, identify barriers, and propose specific improvements with impact-based prioritisation.',
            details: ['Heuristic analysis', 'User flow analysis', 'Prioritised recommendations list', 'Team workshop', 'Output report with mockups'],
            duration: '2–4 weeks',
          },
          {
            num: '02',
            title: 'Eye Tracking',
            desc: 'Precise data on the visual perception of your content. We track eye movements of users interacting with your website, app or print materials.',
            details: ['Attention heatmaps', 'AOI (Areas of Interest) analysis', 'Eye movement recordings', 'F-pattern & Z-pattern analysis', 'Comparative variant testing'],
            duration: '1–3 weeks',
          },
          {
            num: '03',
            title: 'UX Research',
            desc: 'In-depth user research combining qualitative and quantitative methods. We help you understand the needs, frustrations and mental models of your users.',
            details: ['In-depth interviews', 'Contextual research', 'Usability testing', 'Data analysis', 'Personas & Journey maps'],
            duration: '3–8 weeks',
          },
          {
            num: '04',
            title: 'User Testing',
            desc: 'Moderated and unmoderated tests with real users. We observe how users complete tasks in your product and identify where they fail.',
            details: ['Moderated session tests', 'Unmoderated online tests', 'Think-aloud protocol', 'Screen recording', 'Analysis and recommendations'],
            duration: '1–4 weeks',
          },
        ].map(service => (
          <div class="p-8 md:p-12 border-b border-brand-black/10 last:border-0">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <div class="md:col-span-2">
                <div class="flex items-baseline gap-4 mb-4">
                  <span class="font-mono text-xs text-brand-black/30">{service.num}</span>
                  <h2 class="font-display text-3xl md:text-4xl font-bold">{service.title}</h2>
                </div>
                <p class="text-brand-black/60 leading-relaxed mb-6">{service.desc}</p>
                <ul class="space-y-1">
                  {service.details.map(d => (
                    <li class="font-mono text-xs text-brand-black/60 flex gap-2">
                      <span>→</span> {d}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="flex flex-col justify-between">
                <div>
                  <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">PROJECT DURATION</p>
                  <p class="font-display text-lg font-semibold">{service.duration}</p>
                </div>
                <a href="/en/contact" class="inline-block border border-brand-black px-6 py-3 font-mono text-xs tracking-widest uppercase hover:bg-brand-black hover:text-brand-white transition-colors mt-6 text-center">
                  INQUIRE →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
