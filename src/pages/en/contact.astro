---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  lang="en"
  title="Contact"
  description="Contact UX Mind. Book a free consultation for a UX audit, eye tracking or UX research."
>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-16">
        <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ CONTACT ]</p>
        <h1 class="font-display font-bold leading-none tracking-tighter mb-8" style="font-size: clamp(3rem, 9vw, 8rem);">
          LET'S<br/>TALK.
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

        <div>
          <p class="text-xl text-brand-black/60 leading-relaxed mb-12">
            We'd love to hear about your project. Write to us or fill in the form and we'll get back to you within 24 hours.
          </p>

          <div class="space-y-6">
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">EMAIL</p>
              <a href="mailto:info@uxmind.cz" class="font-display text-2xl font-bold hover:opacity-50 transition-opacity">
                info@uxmind.cz
              </a>
            </div>
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">PHONE</p>
              <a href="tel:+420000000000" class="font-display text-2xl font-bold hover:opacity-50 transition-opacity">
                +420 000 000 000
              </a>
            </div>
            <div>
              <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-1">LOCATION</p>
              <p class="font-display text-xl font-bold">Prague, Czech Republic</p>
            </div>
          </div>

          <div class="mt-12 p-6 border border-brand-black/10">
            <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-3">[ WE RESPOND WITHIN ]</p>
            <p class="font-display text-3xl font-bold">24 hours</p>
            <p class="text-sm text-brand-black/50 mt-1">on business days</p>
          </div>
        </div>

        <div>
          <form class="space-y-6" name="contact-en" method="POST" data-netlify="true">
            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">NAME *</label>
              <input
                type="text"
                name="name"
                required
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="Your name"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">EMAIL *</label>
              <input
                type="email"
                name="email"
                required
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">COMPANY</label>
              <input
                type="text"
                name="company"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent"
                placeholder="Company name"
              />
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">SERVICE OF INTEREST</label>
              <select
                name="service"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent appearance-none"
              >
                <option value="">Select a service...</option>
                <option value="ux-audit">UX Audit</option>
                <option value="eye-tracking">Eye Tracking</option>
                <option value="ux-research">UX Research</option>
                <option value="user-testing">User Testing</option>
                <option value="consultation">Consultation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label class="font-mono text-xs text-brand-black/40 tracking-widest block mb-2">MESSAGE *</label>
              <textarea
                name="message"
                required
                rows="5"
                class="w-full border border-brand-black/20 px-4 py-3 font-sans text-base focus:outline-none focus:border-brand-black transition-colors bg-transparent resize-none"
                placeholder="Describe your project or question..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full border border-brand-black px-8 py-4 font-mono text-xs tracking-widest uppercase hover:bg-brand-black hover:text-brand-white transition-colors"
            >
              SEND MESSAGE →
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
