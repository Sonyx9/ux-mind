---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
---

<BaseLayout
  title="Blog"
  description="UX Mind Blog — články o UX výzkumu, eye trackingu, testování uživatelů a designu."
>
  <Navbar />

  <main class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-16">
        <p class="font-mono text-xs text-brand-black/40 tracking-widest mb-4">[ BLOG ]</p>
        <h1 class="font-display font-bold leading-none tracking-tighter" style="font-size: clamp(3rem, 9vw, 8rem);">
          ZNALOSTI<br/>ZDARMA.
        </h1>
      </div>

      <!-- Tags filter -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          <a href="/blog" class="font-mono text-xs border border-brand-black px-3 py-1.5 hover:bg-brand-black hover:text-brand-white transition-colors">
            Vše
          </a>
          {allTags.map(tag => (
            <a href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="font-mono text-xs border border-brand-black/20 px-3 py-1.5 hover:border-brand-black transition-colors">
              {tag}
            </a>
          ))}
        </div>
      )}

      <!-- Featured post -->
      {allPosts[0] && (
        <a href={`/blog/${allPosts[0].slug}`} class="group block mb-16 border border-brand-black/10 hover:border-brand-black transition-colors">
          <div class="grid grid-cols-1 md:grid-cols-2">
            {allPosts[0].data.coverImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={allPosts[0].data.coverImage}
                  alt={allPosts[0].data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-10 flex flex-col justify-between">
              <div>
                <div class="flex gap-2 mb-4">
                  <span class="font-mono text-xs border border-brand-black/20 px-2 py-0.5 text-brand-black/40">FEATURED</span>
                  {allPosts[0].data.tags.slice(0,2).map((tag: string) => (
                    <span class="font-mono text-xs text-brand-black/40">{tag}</span>
                  ))}
                </div>
                <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 leading-tight group-hover:opacity-60 transition-opacity">
                  {allPosts[0].data.title}
                </h2>
                <p class="text-brand-black/60 leading-relaxed">{allPosts[0].data.excerpt}</p>
              </div>
              <div class="flex justify-between items-center mt-8">
                <p class="font-mono text-xs text-brand-black/30">
                  {new Date(allPosts[0].data.date).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
                <span class="font-mono text-xs">ČÍST →</span>
              </div>
            </div>
          </div>
        </a>
      )}

      <!-- Posts grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {allPosts.slice(1).map(post => (
          <a href={`/blog/${post.slug}`} class="group">
            {post.data.coverImage && (
              <div class="aspect-video overflow-hidden mb-4 bg-brand-black/5">
                <img
                  src={post.data.coverImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="flex gap-2 mb-2">
              {post.data.tags.slice(0,2).map((tag: string) => (
                <span class="font-mono text-xs text-brand-black/40">{tag}</span>
              ))}
            </div>
            <h2 class="font-display text-xl font-bold mb-2 leading-tight group-hover:opacity-60 transition-opacity">
              {post.data.title}
            </h2>
            <p class="text-sm text-brand-black/60 leading-relaxed mb-4">{post.data.excerpt}</p>
            <p class="font-mono text-xs text-brand-black/30">
              {new Date(post.data.date).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
          </a>
        ))}
      </div>

      {allPosts.length === 0 && (
        <div class="text-center py-24">
          <p class="text-brand-black/40">Brzy zde přibydou první články.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
